{
  "manifest_version": 3,
  "name": "SmashEnglish Side Translator",
  "version": "0.1.0",
  "description": "A standalone translation side panel extension with in-extension Gemini API calls.",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://learn.nanopixel.uk/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/extension-icon.png",
    "32": "assets/extension-icon.png",
    "48": "assets/extension-icon.png",
    "128": "assets/extension-icon-large.png"
  },
  "action": {
    "default_title": "Open SmashEnglish Translator",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/extension-icon.png",
      "32": "assets/extension-icon.png",
      "48": "assets/extension-icon.png",
      "128": "assets/extension-icon-large.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
